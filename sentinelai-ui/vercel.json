{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "Backend API URL",
      "value": "https://sentinelai-backend.onrender.com"
    },
    "NEXT_PUBLIC_WS_URL": {
      "description": "WebSocket URL",
      "value": "wss://sentinelai-backend.onrender.com"
    }
  }
}
