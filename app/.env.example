# ═══════════════════════════════════════════════
# SentinelAI Environment Variables
# ═══════════════════════════════════════════════

# ── Database (required for production) ──
# Leave blank for SQLite (default). Set for PostgreSQL (Neon, Render, etc).
# Format: postgresql://user:password@host/dbname
# Neon example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ── Redis (optional) ──
# Upstash Redis or any Redis-compatible service. If unset, in-memory cache is used.
# Format: redis://default:password@host:port
REDIS_URL=

# ── Secret Key (required) ──
SECRET_KEY=

# ── Gemini AI (optional) ──
# Get key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── CORS ──
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── SMTP / Email (optional) ──
# Required for OTP email verification and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Frontend (set in Render dashboard) ──
# NEXT_PUBLIC_API_URL=https://sentinelai-backend.onrender.com
