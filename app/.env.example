# ── SentinelAI Backend Configuration ──

# Security (REQUIRED)
SECRET_KEY=your-production-secret-key-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key

# Database (PostgreSQL for production, SQLite for dev)
DATABASE_URL=postgresql://sentinelai:password@localhost:5432/sentinelai
# DATABASE_PATH=./sentinelai.db  # SQLite fallback

# Redis (for caching and event queue)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost

# ── AI/ML ──
GEMINI_API_KEY=your-gemini-api-key

# ── Threat Intelligence APIs ──
ABUSEIPDB_API_KEY=your-abuseipdb-api-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key
SHODAN_API_KEY=your-shodan-api-key

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=SentinelAI <noreply@sentinelai.com>

# ── OTP ──
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5

# ── Agent Configuration ──
AGENT_TOKEN=your-agent-authentication-token
AGENT_HEARTBEAT_INTERVAL=30

# ── Rate Limiting ──
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_INGEST=1000
