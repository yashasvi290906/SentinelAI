# Backend Environment Variables
# Copy this to .env and fill in real values

# Required: JWT signing secret (use a strong random string, min 32 chars)
SECRET_KEY=

# Optional: Gemini API key (AI copilot will use fallback if not set)
GEMINI_API_KEY=

# Database path (defaults to ./sentinelai.db)
DATABASE_PATH=

# CORS origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP Configuration (for OTP emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sentinelai.com

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
